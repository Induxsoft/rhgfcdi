        @"uf_sat_proser" string(50) required
        @"uf_sat_uniproser" string(50) required
    }
    // Usuarios
    entity "tuser" : "TableModel"
    {
        @"locked" bool 
        @"message" string(255) 
        @"notes" memo 
        @"pwd" string(32) 
        @"userid" string(120) unique required
        @"username" string(120) required
        @"pwdmd5" string(64) 
        @"external" bool // Si es true, el usuario se consiera externo.
    }
    // Categorias
    entity "categoria" : "TableModel"
    {
        @"codcuenta" string(50) unique
        @"codigo" string(5) unique required
        @"descripcion" string(50) unique required
        @"pmensual" decimal(18,8)
        @"tipo" ref:"ctiposcategorias"
        @"padre" ref:"categoria"
        @"uf_inhabilitado" bool
        @"uf_fechainhabilitacion" datetime
    }
    // Cardex
    entity "cardex" : "TableModel"
    {
        @"aplicado" bool
        @"descripcion" string(8192)
        @"fecha" date
        @"referencia" string(255) unique required
        @"valuado" bool
        // @"doccompra" ref:"compra"
        // @"docorden" ref:"orden"
        // @"docventa" ref:"venta"
        @"icategoria" ref:"categoria" required
    }

    //* ======================================== [ ENTIDADES PRINCIPALES ]
    // Enumeración de frecuencias para los limites de dotación de insumos
    entity "rhgfcdi_limite_freq":"EnumModel"
    {
        /**
        * 1-Dia
        * 2-Semana calendario
        * 3-Mes calendario
        * 4-Año calendario
        */
    }
    // Almacenes autorizados para proporcionar insumos a empleados
    entity "rhgfcdi_almacen":"TableModel"
    {
        @"ref_almacen" ref:"almacen" required
        @"ref_unidad"  ref:"rh_unidad_org" required
        @"subunidades" bool // Indica si puede usarse en sub-unidades organizacionales
        @"notas" memo // Notas generales
        
        index "almacen_unidad" unique
        {
            field "ref_almacen"
            field "ref_unidad"
        }
    }
    // Administración de límites en la dotación de insumos por puesto
    entity "rhgfcdi_limite":"TableModel"
    {
        @"ref_insumo" ref:"producto" required
        @"ref_puesto" ref:"rh_puesto_org" required
        @"frecuencia" ref:"rhgfcdi_limite_freq" required
        @"intervalo" int required
        @"cantidad" decimal(8,2) required
        @"unidad" string(15) required
        @"costo_adic" bool
        @"precio" decimal(14,4)
    }
    // Gestión de dotación de insumos a empleados
    entity "rhgfcdi_mov" :"TableModel"
    {
        @"ref_empleado" ref:"rh_empleado_org" required
        @"fecha" date required
        @"notas" memo
        @"usuario" ref:"tuser" required // usuario que entrega
        @"producto" ref:"producto" required
        @"unidad" string(15) required
        @"cantidad" decimal(12,4) required
        @"ref_cardex" ref:"cardex" required
        @"excedente" bool
        @"precio" decimal(12,4)
    }

    //* ======================================== [ ... ]
    // Permisos disponibles
    entity "sitem" : "TableModel"
    {
        @"description" string(250)
        @"itemid" string(32) unique required
        @"itemparent" ref:"sitem"
    }
    // Información de la aplicación
    entity "sys_app_catalog"
    {
        @"pack_id" string(32) required
        @"app_id" string(32) key
        @"app_title" string(255)
        @"created" datetime required
        @"app_info" mmemo
    }
    // Categoria de la aplicación
    entity "sys_app_category"
    {
        @"id" string(32) key
        @"title" string(255) required
    }
    // Recursos de la aplicación
    entity "sys_app_shortcut" 
    {
        @"id" string(32) key
        @"title" string(255) required
        @"icon96x96" string(1024) required
        @"src" string(1024) required
        @"_blank" bool
        @"appid" ref:"sys_app_catalog"
        @"cat" ref:"sys_app_category"
    }
    // Tipos de elementos de la aplicación
    entity "sys_app_item_type"
    {
        @"id" string(32) key
        @"title" string(255) required
    }
    // Acciones Generales o Especificas de elementos de la aplicación
    entity "sys_app_item_action"
    {
        @"id" string(32) key
        @"title" string(255) required
        @"shorttitle" string(25) 
        @"icon16x16" string(1024) required
        @"href" string(1024) required
        @"_blank" bool
        @"appid" ref : "sys_app_catalog"
        @"itemtype" ref : "sys_app_item_type"
        @"req_context_item_id" bool
        @"act_type" string(15) //Cadena con el tipo de acción: 'action' o 'report'
    }
}